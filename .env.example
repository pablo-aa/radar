# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Anthropic — required for Managed Agents
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Strategist Managed Agent resources (produced by scripts/strategist/create-resources.ts)
# Run `npm run strategist:setup` once per environment, then paste the output below.
# Lost these? Run `npm run strategist:list` to recover existing ids before creating duplicates.
# ---------------------------------------------------------------------------
STRATEGIST_AGENT_ID=
STRATEGIST_ENVIRONMENT_ID=

# ---------------------------------------------------------------------------
# Scout Managed Agent resources (produced by scripts/scout/create-resources.ts)
# Run `npm run scout:setup` once per environment, then paste the output below.
# ---------------------------------------------------------------------------
SCOUT_AGENT_ID=
SCOUT_ENVIRONMENT_ID=

# ---------------------------------------------------------------------------
# Supabase — required when the web app and DB are wired up
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Admin access
# Comma-separated GitHub handles allowed to force re-run strategist / anamnesis
# during beta testing. E.g.: ADMIN_GITHUB_HANDLES=pabloaa,pablo-aa
# ---------------------------------------------------------------------------
ADMIN_GITHUB_HANDLES=

# ---------------------------------------------------------------------------
# Resend email service
# Required for transactional email (run completion notifications).
# Get at https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# Sender. Defaults to "Radar <onboarding@resend.dev>" if unset.
# Once your domain DNS is configured at https://resend.com/domains, set to
# RESEND_FROM="Radar <radar@radar.pabloaa.com>"
RESEND_FROM=

# Public site URL. Used to build email links (e.g. https://radar.pabloaa.com/report)
# AND for internal HTTP dispatch from /api/intake/submit -> /api/strategist/run.
# In local dev, override to http://localhost:3001 in .env.local.
NEXT_PUBLIC_SITE_URL=https://radar.pabloaa.com

# ---------------------------------------------------------------------------
# Internal dispatch secret
# Shared secret used when /api/intake/submit calls /api/strategist/run from
# inside its after() callback (no user cookie available at that point).
# Generate with: openssl rand -hex 32
# Required in BOTH .env.local AND Vercel for the intake -> strategist chain.
# ---------------------------------------------------------------------------
INTERNAL_DISPATCH_SECRET=
