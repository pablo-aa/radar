# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Anthropic — required for Managed Agents
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Strategist Managed Agent resources (produced by scripts/strategist/create-resources.ts)
# Run `npm run strategist:setup` once per environment, then paste the output below.
# Lost these? Run `npm run strategist:list` to recover existing ids before creating duplicates.
# ---------------------------------------------------------------------------
STRATEGIST_AGENT_ID=
STRATEGIST_ENVIRONMENT_ID=

# ---------------------------------------------------------------------------
# Supabase — required when the web app and DB are wired up
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Admin access
# Comma-separated GitHub handles allowed to force re-run strategist / anamnesis
# during beta testing. E.g.: ADMIN_GITHUB_HANDLES=pabloaa,pablo-aa
# ---------------------------------------------------------------------------
ADMIN_GITHUB_HANDLES=
